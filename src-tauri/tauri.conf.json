{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LANChat",
  "version": "0.1.1",
  "identifier": "com.lanchat.app", 
  "build": {
    "frontendDist": "../src"
  },
  "app": {
		"withGlobalTauri": true,
    "windows": [
      {
				"label": "main",
        "title": "LANChat",
        "width": 900,
        "height": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
