{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:path:default",
    "fs:default",
    "fs:allow-write-file",
    "fs:allow-remove",
    "fs:allow-stat",
    "dialog:default",
    "sql:default",
    "log:default",
    "shell:default",
    "allow-get-my-name",
    "allow-get-my-id",
    "allow-update-my-name",
    "allow-get-peers",
    "allow-send-message",
    "allow-get-chat-history",
    "allow-get-chat-history-with-offset",
    "allow-send-file",
    "allow-get-settings",
    "allow-update-settings",
    "allow-get-theme-list",
    "allow-get-theme-css",
    "allow-save-current-theme",
    "allow-get-current-theme",
    "allow-accept-file",
    "allow-get-default-download-path",
    "allow-request-storage-permission",
    "allow-save-file-message",
    "allow-open-file-location",
    "allow-read-clipboard-files",
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "allow": [
        { "path": "[a-zA-Z]:**" },
        { "path": "/**" }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$TEMP/**" },
        { "path": "**" }
      ]
    }
  ]
}
